{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "SSMAccess",
        "Effect": "Allow",
        "Action": [
          "ssm:GetParameter",
          "ssm:DescribeParameters"
        ],
        "Resource": "arn:aws:ssm:us-east-1:931163289790:parameter/roboshop/${environment}/mysql_root_password"
      },
      {
        "Sid": "KMSDecrypt",
        "Effect": "Allow",
        "Action": "kms:Decrypt",
        "Resource": "*"
      }
    ]
  }